{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "MongoDB": "mongodb+srv://<USERNAME>:<PASSWORD>@cluster.mongodb.net/CreateadTournament?retryWrites=true&w=majority"
  },
  "JwtSettings": {
    "SecretKey": "<YOUR_SECRET_KEY>",
    "Issuer": "SportHub",
    "Audience": "SportHubUsers",
    "AccessTokenExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 7
  },
  "AllowedHosts": "*"
}
